    <!-- 修改 updatePoints 方法，使用 owner_id 而不是 user_id -->
    <update id="updatePoints" parameterType="OwnerPoints">
        update sys_owner_info
        set
        occupation = #{points},
        update_by = #{updateBy},
        update_time = sysdate()
        where owner_id = #{ownerId}
        <if test="updateTime != null">
            and update_time = #{updateTime}
        </if>
    </update>

    <!-- 添加带乐观锁的积分更新方法 -->
    <update id="updatePointsWithLock" parameterType="OwnerPoints">
        update sys_owner_info
        set
        occupation = #{points},
        update_by = #{updateBy},
        update_time = sysdate()
        where owner_id = #{ownerId}
        <if test="updateTime != null">
            and update_time = #{updateTime}
        </if>
        <if test="updateTime == null">
            and update_time is null
        </if>
    </update>

    <delete id="deleteOwnerPointsById" parameterType="Long">
        delete from sys_owner_info where owner_id = #{ownerId}
    </delete>

    <delete id="deleteOwnerPointsByIds" parameterType="Long">
        delete from sys_owner_info where owner_id in
        <foreach item="ownerId" collection="array" open="(" separator="," close=")">
            #{ownerId}
        </foreach>
    </delete>
</mapper>