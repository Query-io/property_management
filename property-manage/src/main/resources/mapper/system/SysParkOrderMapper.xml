<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.property.system.mapper.SysParkOrderMapper">

    <resultMap type="SysParkOrder" id="ParkOrderResult">
        <id     property="id"         column="id"/>
        <result property="parkId"       column="park_id"/>
        <result property="type"     column="type"/>
        <result property="plateColor"       column="plate_color"/>
        <result property="plateNum"       column="plate_num"/>
        <result property="entryTime"           column="entry_time"/>
        <result property="exitTime"      column="exit_time"/>
        <result property="parkingDuration"          column="parking_duration"/>
        <result property="parkFee"      column="park_fee"/>
        <result property="delFlag"        column="del_flag"/>
        <result property="userId"        column="user_id"/>
        <result property="userName"       column="user_name"/>
        <result property="parkName"        column="park_name"/>
        <result property="status"   column="status"/>
    </resultMap>

    <!-- 查询全部停车订单（可根据条件查询） -->
    <select id="selectParkOrderList" resultMap="ParkOrderResult" parameterType="com.property.system.domain.SysParkOrder">
        SELECT po.* , su.user_name, pi.park_name
        FROM sys_park_order po
        LEFT JOIN  sys_user su on po.user_id = su.user_id
        LEFT JOIN  sys_park_info pi on pi.park_id = po.park_id
        <where>
            <if test="parkId != null">
                AND park_id = #{parkId}
            </if>
            <if test="type != null">
                AND type = #{type}
            </if>
            <if test="plateColor != null and plateColor != ''">
                AND plate_color LIKE CONCAT('%', #{plateColor}, '%')
            </if>
            <if test="plateNum != null and plateNum != ''">
                AND plate_num LIKE CONCAT('%', #{plateNum}, '%')
            </if>
            <if test="delFlag != null">
                AND del_flag = #{delFlag}
            </if>
        </where>
    </select>

    <!-- 根据 userId 和车牌号查询用户最新的停车订单 -->
    <select id="selectLatestOrderByUserIdAndPlateNum" resultMap="ParkOrderResult" resultType="com.property.system.domain.SysParkOrder">
        SELECT * FROM sys_park_order
        WHERE user_id = #{userId} AND plate_num = #{plateNum}
        ORDER BY entry_time DESC
            LIMIT 1
    </select>


    <!-- 根据订单id 查询订单-->
    <select id="selectParkOrderById" resultMap="ParkOrderResult" resultType="com.property.system.domain.SysParkOrder">
        SELECT po.* , su.user_name, pi.park_name
        FROM sys_park_order po
        LEFT JOIN  sys_user su on po.user_id = su.user_id
        LEFT JOIN  sys_park_info pi on pi.park_id = po.park_id
        WHERE id = #{id}
    </select>
    <!-- 插入停车订单 -->
    <insert id="insertParkOrder" parameterType="com.property.system.domain.SysParkOrder">
        INSERT INTO sys_park_order (
            park_id, type, plate_color, plate_num, entry_time, exit_time,
            parking_duration, park_fee, del_flag,user_id
        ) VALUES (
                     #{parkId}, #{type}, #{plateColor}, #{plateNum}, #{entryTime}, #{exitTime},
                     #{parkingDuration}, #{parkFee}, #{delFlag},#{userId}
                 )
    </insert>

    <!-- 更新停车订单 -->
    <update id="updateParkOrder" parameterType="com.property.system.domain.SysParkOrder">
        UPDATE sys_park_order
        <set>
        <if test="parkId != null">
            park_id = #{parkId},
        </if>
        <if test="type != null">
            type = #{type},
        </if>
        <if test="plateColor != null and plateColor != ''">
            plate_color = #{plateColor},
        </if>
        <if test="plateNum != null and plateNum != ''">
            plate_num = #{plateNum},
        </if>
        <if test="entryTime != null">
            entry_time = #{entryTime},
        </if>
        <if test="exitTime != null">
            exit_time = #{exitTime},
        </if>
        <if test="parkingDuration != null">
            parking_duration = #{parkingDuration},
        </if>
        <if test="parkFee != null">
            park_fee = #{parkFee},
        </if>
        <if test="delFlag != null and delFlag != ''">
            del_flag = #{delFlag},
        </if>
        <if test="status != null and status !=''">
            status = #{status},
        </if>
        </set>
        WHERE id = #{id}
    </update>
    <!-- 删除停车订单 -->
    <delete id="deleteParkOrderById" parameterType="long">
        DELETE FROM sys_park_order WHERE id = #{id}
    </delete>

</mapper>
