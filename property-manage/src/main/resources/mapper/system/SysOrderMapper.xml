<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.property.system.mapper.SysOrderMapper">

    <!-- 订单结果映射 -->
    <resultMap id="SysOrderResult" type="com.property.system.domain.SysOrder">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="orderType" column="order_type"/>
        <result property="userId" column="user_id"/>
        <result property="propertyId" column="property_id"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="actualAmount" column="actual_amount"/>
        <result property="pointsUsed" column="points_used"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="payTime" column="pay_time"/>
        <result property="userName" column="user_name"/>
        <result property="propertyAddress" column="property_address"/>
        <result property="associationId" column="association_id"/>
    </resultMap>

    <!-- 查询列表 -->
    <select id="selectSysOrderList" parameterType="com.property.system.domain.SysOrder" resultMap="SysOrderResult">
        SELECT
        sys_order.*,sys_property_info.property_address
        FROM sys_order
        left join sys_property_info  on sys_order.property_id = sys_property_info.property_id
        WHERE 1 = 1
        <if test="userId != null and userId != ''">
            AND sys_order.user_id = #{userId}
        </if>
        <if test="userName != null and userName != ''">
            AND sys_order.user_name LIKE CONCAT('%', #{userName}, '%')
        </if>
        <if test="orderNo != null and orderNo != ''">
            AND sys_order.order_no like CONCAT('%', #{orderNo}, '%')
        </if>
        <if test="orderType != null and orderType != ''">
            AND sys_order.order_type = #{orderType}
        </if>
        <if test="status != null and status != ''">
            AND sys_order.status = #{status}
        </if>
        ORDER BY sys_order.create_time DESC
    </select>

    <!-- 查询单个订单 -->
    <select id="selectSysOrderById" parameterType="Long" resultMap="SysOrderResult">
        SELECT * FROM sys_order WHERE id = #{id}
    </select>

    <!-- 新增订单 -->
    <insert id="insertSysOrder" parameterType="com.property.system.domain.SysOrder" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_order (
        <if test="orderNo != null and orderNo != ''">order_no,</if>
        <if test="orderType != null and orderType != ''">order_type,</if>
        <if test="userId != null">user_id,</if>
        <if test="propertyId != null">property_id,</if>
        <if test="totalAmount != null">total_amount,</if>
        <if test="actualAmount != null">actual_amount,</if>
        <if test="pointsUsed != null">points_used,</if>
        <if test="status != null and status != ''">status,</if>
        <if test="remark != null and remark != ''">remark,</if>
        <if test="userName != null and userName != ''">user_name,</if>
        <if test="payTime != null">pay_time,</if>
        <if test="associationId != null and associationId != ''">association_id,</if>
        create_time
        ) VALUES (
        <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
        <if test="orderType != null and orderType != ''">#{orderType},</if>
        <if test="userId != null">#{userId},</if>
        <if test="propertyId != null">#{propertyId},</if>
        <if test="totalAmount != null">#{totalAmount},</if>
        <if test="actualAmount != null">#{actualAmount},</if>
        <if test="pointsUsed != null">#{pointsUsed},</if>
        <if test="status != null and status != ''">#{status},</if>
        <if test="remark != null and remark != ''">#{remark},</if>
        <if test="userName != null and userName != ''">#{userName},</if>
        <if test="payTime != null">#{payTime},</if>
        <if test="associationId != null and associationId != ''">#{associationId},</if>
        NOW()
        )
    </insert>


    <!-- 修改订单状态（支付时更新实付金额和积分） -->
    <update id="updateSysOrderStatus" parameterType="com.property.system.domain.SysOrder">
        UPDATE sys_order
        <set>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="actualAmount != null">actual_amount = #{actualAmount},</if>
            <if test="pointsUsed != null">points_used = #{pointsUsed},</if>
            <if test="status != null and status != ''">pay_time = NOW()</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除订单 -->
    <delete id="deleteSysOrderById" parameterType="Long">
        DELETE FROM sys_order WHERE id = #{id}
    </delete>

    <!-- ========== 明细 ========== -->

    <!-- 明细结果映射 -->
    <resultMap id="SysOrderItemResult" type="com.property.system.domain.SysOrderItem">
        <id property="id" column="id"/>
        <result property="orderId" column="order_id"/>
        <result property="itemName" column="item_name"/>
        <result property="quantity" column="quantity"/>
        <result property="unitPrice" column="unit_price"/>
        <result property="amount" column="amount"/>
        <result property="description" column="description"/>
        <result property="associationId" column="association_id"/>
    </resultMap>

    <!-- 查询明细列表 -->
    <select id="selectSysOrderItemList" parameterType="Long" resultMap="SysOrderItemResult">
        SELECT * FROM sys_order_item WHERE order_id = #{orderId}
    </select>

    <!-- 插入明细（单条） -->
    <insert id="insertOrderItem" parameterType="com.property.system.domain.SysOrderItem"  useGeneratedKeys="true" keyProperty="id">
        insert into sys_order_item (
        <if test="itemName != null and itemName != ''">item_name,</if>
        <if test="quantity != null">quantity,</if>
        <if test="unitPrice != null">unit_price,</if>
        <if test="amount != null">amount,</if>
        <if test="description != null and description != ''">description,</if>
        order_id
        ) values (
        <if test="itemName != null and itemName != ''">#{itemName},</if>
        <if test="quantity != null">#{quantity},</if>
        <if test="unitPrice != null">#{unitPrice},</if>
        <if test="amount != null">#{amount},</if>
        <if test="description != null and description != ''">#{description},</if>
        #{orderId}
        )
    </insert>

    <!-- 更新明细（单条） -->
    <update id="updateOrderItem" parameterType="com.property.system.domain.SysOrderItem">
        UPDATE sys_order_item
        <set>
            <if test="itemName != null and itemName != ''">item_name = #{itemName},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="unitPrice != null">unit_price = #{unitPrice},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="description != null and description != ''">description = #{description},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除所有明细（按订单ID） -->
    <delete id="deleteOrderItemsByOrderId" parameterType="Long">
        DELETE FROM sys_order_item WHERE order_id = #{orderId}
    </delete>

</mapper>