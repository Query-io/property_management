<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.property.system.mapper.SysViolationRecordMapper">

    <resultMap type="SysViolationRecord" id="SysViolationRecordResult">
        <result property="violationId" column="violation_id"/>
        <result property="plateNum" column="plate_num"/>
        <result property="violationType" column="violation_type"/>
        <result property="violationTime" column="violation_time"/>
        <result property="location" column="location"/>
        <result property="description" column="description"/>
        <result property="evidenceImg" column="evidence_img"/>
        <result property="status" column="status"/>
        <result property="penaltyAmount" column="penalty_amount"/>
        <result property="penaltyDate" column="penalty_date"/>
        <result property="processorId" column="processor_id"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="processorName" column="processor_name"/>
    </resultMap>

    <sql id="selectViolationVo">
        select vr.violation_id, vr.plate_num, vr.violation_type, vr.violation_time,
               vr.location, vr.description, vr.evidence_img, vr.status,
               vr.penalty_amount, vr.penalty_date, vr.processor_id, vr.remark,
               vr.create_by, vr.create_time, vr.update_by, vr.update_time,
               u.user_name as processor_name
        from sys_violation_record vr
                 left join sys_user u on vr.processor_id = u.user_id
    </sql>

    <select id="selectViolationList" parameterType="SysViolationRecord" resultMap="SysViolationRecordResult">
        <include refid="selectViolationVo"/>
        <where>
            <if test="plateNum != null and plateNum != ''">
                AND vr.plate_num like concat('%', #{plateNum}, '%')
            </if>
            <if test="violationType != null and violationType != ''">
                AND vr.violation_type = #{violationType}
            </if>
            <if test="status != null">
                AND vr.status = #{status}
            </if>
            <if test="beginTime != null">
                AND vr.violation_time >= #{beginTime}
            </if>
            <if test="endTime != null">
                AND vr.violation_time <![CDATA[ <= ]]> #{endTime}
            </if>
        </where>
        order by vr.violation_time desc
    </select>

    <select id="selectViolationAll" resultMap="SysViolationRecordResult">
        <include refid="selectViolationVo"/>
        order by vr.violation_time desc
    </select>

    <select id="selectViolationById" parameterType="Long" resultMap="SysViolationRecordResult">
        <include refid="selectViolationVo"/>
        where vr.violation_id = #{violationId}
    </select>

    <select id="selectViolationByPlateNum" parameterType="String" resultMap="SysViolationRecordResult">
        <include refid="selectViolationVo"/>
        where vr.plate_num = #{plateNum}
        order by vr.violation_time desc
    </select>

    <select id="countViolationRecords" parameterType="SysViolationRecord" resultType="int">
        select count(1) from sys_violation_record
        <where>
            <if test="plateNum != null and plateNum != ''">
                AND plate_num like concat('%', #{plateNum}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="beginTime != null">
                AND violation_time >= #{beginTime}
            </if>
            <if test="endTime != null">
                AND violation_time <![CDATA[ <= ]]> #{endTime}
            </if>
        </where>
    </select>

    <select id="countViolationByType" parameterType="map" resultType="map">
        select
        violation_type as type,
        count(1) as count,
        sum(penalty_amount) as totalAmount
        from sys_violation_record
        <where>
            <if test="beginTime != null">
                AND violation_time >= #{beginTime}
            </if>
            <if test="endTime != null">
                AND violation_time <![CDATA[ <= ]]> #{endTime}
            </if>
        </where>
        group by violation_type
        order by count desc
    </select>

    <select id="countPendingViolations" resultType="int">
        select count(1) from sys_violation_record where status = 0
    </select>

    <insert id="insertViolation" parameterType="SysViolationRecord" useGeneratedKeys="true" keyProperty="violationId">
        insert into sys_violation_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="plateNum != null and plateNum != ''">plate_num,</if>
            <if test="violationType != null and violationType != ''">violation_type,</if>
            <if test="violationTime != null">violation_time,</if>
            <if test="location != null">location,</if>
            <if test="description != null">description,</if>
            <if test="evidenceImg != null">evidence_img,</if>
            <if test="status != null">status,</if>
            <if test="penaltyAmount != null">penalty_amount,</if>
            <if test="penaltyDate != null">penalty_date,</if>
            <if test="processorId != null">processor_id,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="plateNum != null and plateNum != ''">#{plateNum},</if>
            <if test="violationType != null and violationType != ''">#{violationType},</if>
            <if test="violationTime != null">#{violationTime},</if>
            <if test="location != null">#{location},</if>
            <if test="description != null">#{description},</if>
            <if test="evidenceImg != null">#{evidenceImg},</if>
            <if test="status != null">#{status},</if>
            <if test="penaltyAmount != null">#{penaltyAmount},</if>
            <if test="penaltyDate != null">#{penaltyDate},</if>
            <if test="processorId != null">#{processorId},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateViolation" parameterType="SysViolationRecord">
        update sys_violation_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="plateNum != null and plateNum != ''">plate_num = #{plateNum},</if>
            <if test="violationType != null and violationType != ''">violation_type = #{violationType},</if>
            <if test="violationTime != null">violation_time = #{violationTime},</if>
            <if test="location != null">location = #{location},</if>
            <if test="description != null">description = #{description},</if>
            <if test="evidenceImg != null">evidence_img = #{evidenceImg},</if>
            <if test="status != null">status = #{status},</if>
            <if test="penaltyAmount != null">penalty_amount = #{penaltyAmount},</if>
            <if test="penaltyDate != null">penalty_date = #{penaltyDate},</if>
            <if test="processorId != null">processor_id = #{processorId},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where violation_id = #{violationId}
    </update>

    <update id="updateViolationStatus">
        update sys_violation_record
        set status = #{status},
        processor_id = #{processorId},
        <if test="status == 1">
            penalty_date = now(),
        </if>
        update_by = #{updateBy},
        update_time = now()
        where violation_id = #{violationId}
    </update>

    <delete id="deleteViolationById" parameterType="Long">
        delete from sys_violation_record where violation_id = #{violationId}
    </delete>

    <delete id="deleteViolationByIds" parameterType="Long">
        delete from sys_violation_record where violation_id in
        <foreach item="violationId" collection="array" open="(" separator="," close=")">
            #{violationId}
        </foreach>
    </delete>
</mapper>