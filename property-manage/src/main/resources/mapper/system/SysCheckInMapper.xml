<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.property.system.mapper.SysCheckInMapper">

    <resultMap type="SysCheckIn" id="SysCheckInResult">
        <result property="checkInId" column="check_in_id"/>
        <result property="propertyId" column="property_id"/>
        <result property="ownerId" column="owner_id"/>
        <result property="ownerName" column="owner_name"/>
        <result property="checkInDate" column="check_in_date"/>
        <result property="expectedDuration" column="expected_duration"/>
        <result property="contractNumber" column="contract_number"/>
        <result property="rentalAmount" column="rental_amount"/>
        <result property="depositAmount" column="deposit_amount"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <!-- 关联查询字段 -->
        <result property="propertyAddress" column="property_address"/>
        <result property="region" column="region"/>
        <result property="buildingNo" column="building_no"/>
        <result property="roomNo" column="room_no"/>
    </resultMap>

    <sql id="selectSysCheckInVo">
        select c.check_in_id,
               c.property_id,
               c.owner_id,
               c.owner_name,
               c.check_in_date,
               c.expected_duration,
               c.contract_number,
               c.rental_amount,
               c.deposit_amount,
               c.status,
               c.remark,
               c.create_time,
               c.update_time,
               c.create_by,
               c.update_by,
               p.property_address,
               p.region,
               p.building_no,
               p.room_no
        from sys_check_in c
                 left join sys_property_info p on c.property_id = p.property_id
    </sql>

    <select id="selectSysCheckInByCheckInId" parameterType="Long" resultMap="SysCheckInResult">
        <include refid="selectSysCheckInVo"/>
        where c.check_in_id = #{checkInId}
    </select>

    <select id="selectSysCheckInList" parameterType="SysCheckIn" resultMap="SysCheckInResult">
        <include refid="selectSysCheckInVo"/>
        <where>
            <if test="ownerName != null  and ownerName != ''">and c.owner_name like concat('%', #{ownerName}, '%')</if>
            <if test="propertyId != null ">and c.property_id = #{propertyId}</if>
            <if test="ownerId != null ">and c.owner_id = #{ownerId}</if>
            <if test="checkInDate != null ">and date(c.check_in_date) = date(#{checkInDate})</if>
            <if test="contractNumber != null  and contractNumber != ''">and c.contract_number like concat('%',
                #{contractNumber}, '%')
            </if>
            <if test="status != null  and status != ''">and c.status = #{status}</if>
            <if test="propertyAddress != null  and propertyAddress != ''">and p.property_address like concat('%',
                #{propertyAddress}, '%')
            </if>
            <if test="buildingNo != null  and buildingNo != ''">and p.building_no like concat('%', #{buildingNo}, '%')
            </if>
            <if test="roomNo != null  and roomNo != ''">and p.room_no like concat('%', #{roomNo}, '%')</if>
        </where>
        order by c.check_in_date desc
    </select>

    <insert id="insertSysCheckIn" parameterType="SysCheckIn" useGeneratedKeys="true" keyProperty="checkInId">
        insert into sys_check_in
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="propertyId != null">property_id,</if>
            <if test="ownerId != null">owner_id,</if>
            <if test="ownerName != null">owner_name,</if>
            <if test="checkInDate != null">check_in_date,</if>
            <if test="expectedDuration != null">expected_duration,</if>
            <if test="contractNumber != null">contract_number,</if>
            <if test="rentalAmount != null">rental_amount,</if>
            <if test="depositAmount != null">deposit_amount,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="createBy != null">create_by,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="propertyId != null">#{propertyId},</if>
            <if test="ownerId != null">#{ownerId},</if>
            <if test="ownerName != null">#{ownerName},</if>
            <if test="checkInDate != null">#{checkInDate},</if>
            <if test="expectedDuration != null">#{expectedDuration},</if>
            <if test="contractNumber != null">#{contractNumber},</if>
            <if test="rentalAmount != null">#{rentalAmount},</if>
            <if test="depositAmount != null">#{depositAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="createBy != null">#{createBy},</if>
        </trim>
    </insert>

    <update id="updateSysCheckIn" parameterType="SysCheckIn">
        update sys_check_in
        <trim prefix="SET" suffixOverrides=",">
            <if test="propertyId != null">property_id = #{propertyId},</if>
            <if test="ownerId != null">owner_id = #{ownerId},</if>
            <if test="ownerName != null">owner_name = #{ownerName},</if>
            <if test="checkInDate != null">check_in_date = #{checkInDate},</if>
            <if test="expectedDuration != null">expected_duration = #{expectedDuration},</if>
            <if test="contractNumber != null">contract_number = #{contractNumber},</if>
            <if test="rentalAmount != null">rental_amount = #{rentalAmount},</if>
            <if test="depositAmount != null">deposit_amount = #{depositAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
        </trim>
        where check_in_id = #{checkInId}
    </update>

    <delete id="deleteSysCheckInByCheckInId" parameterType="Long">
        delete
        from sys_check_in
        where check_in_id = #{checkInId}
    </delete>

    <delete id="deleteSysCheckInByCheckInIds" parameterType="String">
        delete from sys_check_in where check_in_id in
        <foreach item="checkInId" collection="array" open="(" separator="," close=")">
            #{checkInId}
        </foreach>
    </delete>
</mapper>