<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.property.system.mapper.InvestmentInfoMapper">

    <resultMap type="InvestmentInfo" id="InvestmentInfoResult">
        <result property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="location" column="location"/>
        <result property="area" column="area"/>
        <result property="rentPrice" column="rent_price"/>
        <result property="contactPerson" column="contact_person"/>
        <result property="contactPhone" column="contact_phone"/>
        <result property="status" column="status"/>
        <result property="publishTime" column="publish_time"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectInvestmentInfoVo">
        select id, title, content, location, area, rent_price, contact_person, contact_phone, status, publish_time, create_by, create_time, update_by, update_time, remark from investment_info
    </sql>

    <select id="selectInvestmentInfoList" parameterType="InvestmentInfo" resultMap="InvestmentInfoResult">
        <include refid="selectInvestmentInfoVo"/>
        <where>
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}, '%')
            </if>
            <if test="location != null and location != ''">
                AND location like concat('%', #{location}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="contactPerson != null and contactPerson != ''">
                AND contact_person like concat('%', #{contactPerson}, '%')
            </if>
            <if test="publishTime != null">
                AND date_format(publish_time,'%y%m%d') = date_format(#{publishTime},'%y%m%d')
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectInvestmentInfoById" parameterType="Long" resultMap="InvestmentInfoResult">
        <include refid="selectInvestmentInfoVo"/>
        where id = #{id}
    </select>

    <insert id="insertInvestmentInfo" parameterType="InvestmentInfo" useGeneratedKeys="true" keyProperty="id">
        insert into investment_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="content != null">content,</if>
            <if test="location != null and location != ''">location,</if>
            <if test="area != null">area,</if>
            <if test="rentPrice != null">rent_price,</if>
            <if test="contactPerson != null and contactPerson != ''">contact_person,</if>
            <if test="contactPhone != null and contactPhone != ''">contact_phone,</if>
            <if test="status != null">status,</if>
            <if test="publishTime != null">publish_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="content != null">#{content},</if>
            <if test="location != null and location != ''">#{location},</if>
            <if test="area != null">#{area},</if>
            <if test="rentPrice != null">#{rentPrice},</if>
            <if test="contactPerson != null and contactPerson != ''">#{contactPerson},</if>
            <if test="contactPhone != null and contactPhone != ''">#{contactPhone},</if>
            <if test="status != null">#{status},</if>
            <if test="publishTime != null">#{publishTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateInvestmentInfo" parameterType="InvestmentInfo">
        update investment_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="location != null and location != ''">location = #{location},</if>
            <if test="area != null">area = #{area},</if>
            <if test="rentPrice != null">rent_price = #{rentPrice},</if>
            <if test="contactPerson != null and contactPerson != ''">contact_person = #{contactPerson},</if>
            <if test="contactPhone != null and contactPhone != ''">contact_phone = #{contactPhone},</if>
            <if test="status != null">status = #{status},</if>
            <if test="publishTime != null">publish_time = #{publishTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteInvestmentInfoById" parameterType="Long">
        delete from investment_info where id = #{id}
    </delete>

    <delete id="deleteInvestmentInfoByIds" parameterType="String">
        delete from investment_info where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>